*.zip
*.tar.gz
*.rar

# 大文件
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.mkv

# 图片文件（可选，根据需要调整）
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.svg
*.ico

# 字体文件
*.ttf
*.otf
*.woff
*.woff2
*.eot

# 其他
