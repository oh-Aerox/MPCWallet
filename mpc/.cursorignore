# Cursor 编辑器忽略文件配置

# 依赖目录
node_modules/
*/node_modules/

# 构建输出
dist/
build/
*/dist/
*/build/

# 日志文件
*.log
logs/
*/logs/

# 环境变量文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 缓存目录
.cache/
.npm/
.yarn/

# 临时文件
*.tmp
*.temp
.tmp/
.temp/

# 操作系统生成的文件
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE 配置文件
.vscode/
.idea/
*.sublime-*
.atom/

# 版本控制
.git/
.gitignore



# 测试覆盖率
coverage/
*.lcov

# 文档生成
docs/_build/
docs/.doctrees/

# 上传文件
uploads/
public/uploads/

# 密钥和证书
*.pem
*.key
*.crt
*.p12
*.pfx

# 备份文件
*.bak
*.backup
*_backup/

